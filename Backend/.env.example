# UTM Borrow — backend environment template.
# Copy to `.env` for local dev, or set these as environment variables on your host.
# NEVER commit the real .env (it is gitignored).

# MongoDB connection.
#   Local:  mongodb://localhost:27017
#   Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"

# Logical database name (collections are created inside it).
DB_NAME="utm_borrow"

# Secrets — GENERATE FRESH RANDOM VALUES FOR PRODUCTION.
# e.g.  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="change-me-generate-a-64-char-hex-secret"
QR_HMAC_SECRET="change-me-generate-a-different-64-char-hex-secret"

# Comma-separated list of allowed browser origins (the frontend URLs).
#   Local:       http://localhost:3000,http://localhost:3001
#   Production:  https://your-app.vercel.app,https://alsakkaf.site
# Do NOT use "*" in production: credentials are enabled and wildcards are rejected by browsers.
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
