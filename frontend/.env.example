# UTM Borrow — frontend environment template.
# Base URL of the FastAPI backend (NO trailing slash, NO /api suffix — the app appends /api).
#   Local:       http://localhost:8000
#   Production:  https://utm-borrow-api.onrender.com   (The Render backend URL)


REACT_APP_BACKEND_URL="http://localhost:8000"

# CRA dev-server websocket port for hot reload.
WDS_SOCKET_PORT=443
